# Copy to .env.local — never commit .env.local

# Subsplash — server-only service credentials (client_credentials grant)
# SUBSPLASH_USE_MOCK: "true" (default) serves lib/mockData.ts fixtures instead
# of calling Subsplash — flip to "false" only once wiring the real API (ADR-0004).
SUBSPLASH_USE_MOCK=true
SUBSPLASH_BASE_URL=https://core.subsplash.com
SUBSPLASH_ORG_KEY=your_org_key_here
SUBSPLASH_CLIENT_ID=your_client_id_here
SUBSPLASH_CLIENT_SECRET=your_client_secret_here
# ADR-0010: name of the Subsplash custom field that grants a personal-email
# volunteer read-only access. Optional — defaults to "Directory Access".
# Church admins set this field to "Yes" on an approved volunteer's profile.
# SUBSPLASH_ACCESS_FIELD_NAME=Directory Access

# Staff auth — Google Workspace SSO via Auth.js (NextAuth v5)
# ADR-001: separate from Subsplash, restricted to the church's Workspace domain.
# ADR-0010: volunteers sign in with a personal Google account and get read-only
# access if flagged via the Subsplash custom field above.
AUTH_SECRET=a_random_32_char_string_for_signing
AUTH_GOOGLE_ID=your_google_oauth_client_id
AUTH_GOOGLE_SECRET=your_google_oauth_client_secret
CHURCH_GOOGLE_WORKSPACE_DOMAIN=gracechapel.org
# Auth.js only trusts the request Host when it knows the deployment is safe.
# Vercel is auto-detected, but set this to "true" for any other host (or a
# local production build via `next start`), otherwise every page 500s with
# UntrustedHost. Add the production callback URL
# https://<your-domain>/api/auth/callback/google to the Google OAuth client.
AUTH_TRUST_HOST=true

# Roles — ADR-002: admin emails, comma-separated, resolved by lib/roles.ts
ADMIN_EMAILS=pastor@gracechapel.org,office@gracechapel.org

# Email — Resend (ADR-0014), used by the Children page's "Email Parents"
# feature. RESEND_API_KEY: server-only, from resend.com. Leave unset for
# local dev — sends are logged to the console instead of actually going out,
# mirroring SUBSPLASH_USE_MOCK's mock-by-default approach.
RESEND_API_KEY=your_resend_api_key_here
# Must be on a domain verified with Resend. The signed-in staff/volunteer's
# name becomes the display name and their email becomes Reply-To, so replies
# go to them, not this address.
EMAIL_FROM_ADDRESS=notifications@gracechapel.org

NEXT_PUBLIC_APP_NAME=STSA Church Directory
